# Environment variables — copy to .env and fill in values

# Application
NODE_ENV=development
PORT=3001

# CORS — comma-separated list of allowed origins
# Leave blank or set to * to allow all origins (dev only)
ALLOWED_ORIGINS=https://your-shopify-store.myshopify.com,https://your-api.vercel.app

# Shopify App Proxy — HMAC validation
# Found in: Partner Dashboard → Your App → Client credentials → Client secret
# Used to verify that incoming /api/proxy/* requests genuinely came from Shopify.
SHOPIFY_CLIENT_SECRET=your_shopify_client_secret_here

